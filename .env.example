# URL base de la API
# Desarrollo: usar ruta relativa → el proxy Vite (vite.config.js) la reenvía al backend
VITE_API_URL=/api/v1

# Producción: URL absoluta al backend
# VITE_API_URL=https://api.turnoflow.co/api/v1

# Dominio raíz de la plataforma (sin protocolo, sin trailing slash)
# Desarrollo: dejar vacío (usa turnoflow.co como fallback, pero no aplica en localhost)
# Probeta VPS: VITE_PLATFORM_DOMAIN=turnoflow.probeta.dev
# Producción:  VITE_PLATFORM_DOMAIN=turnoflow.com
VITE_PLATFORM_DOMAIN=turnoflow.co

# Entorno de la app
VITE_APP_ENV=development
